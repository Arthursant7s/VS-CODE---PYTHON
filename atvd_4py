import os 

os.system("cls || clear")

pares = 0
impares = 0

#Mostrar quantos números pares e ímpares foram digitados
for numero in range(5):  
     num = int(input(f"Digite um número inteiro: "))
     if numero % 2 == 0: 
         pares += 1
     else:
        impares += 1
        
print(f"Pares: {pares}")
print(f"Ímpares: {impares}")